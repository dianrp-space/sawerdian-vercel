# =========================================
# Server
# =========================================
PORT=3003
NODE_ENV=development
# LOG_QUERIES=1                     # Debug SQL di dev

# =========================================
# Database PostgreSQL (WAJIB)
# =========================================
DATABASE_URL=postgresql://sawerdian:YOUR_PASSWORD@103.195.190.67:5432/sawerdian

# =========================================
# Admin Login
# =========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123              # Ganti!
SESSION_SECRET=ganti_dengan_string_random_panjang_minimal_32_karakter
# COOKIE_SECURE=true                 # Paksa secure cookie (jika di belakang HTTPS proxy)

# =========================================
# Payment API payment.dianrp.com (WAJIB)
# =========================================
PAYMENT_API_BASE=https://payment.dianrp.com
PAYMENT_API_KEY=drp_live_xxxx        # Ganti dengan API key kamu!

# =========================================
# S3 Storage (MinIO) — untuk upload avatar/banner (WAJIB)
# =========================================
S3_ENDPOINT=https://s3.dianrp.com
S3_REGION=auto
S3_ACCESS_KEY=                       # Isi access key MinIO
S3_SECRET_KEY=                       # Isi secret key MinIO
S3_BUCKET=public-bucket
S3_PATH_PREFIX=                      # Nama folder (misal: sawerdian)

# =========================================
# Webhook Secret — konfirmasi manual via header X-Webhook-Secret (opsional)
# =========================================
WEBHOOK_SECRET=ganti_dengan_string_random

# =========================================
# CORS — kosongkan jika frontend & backend satu domain
# =========================================
ALLOWED_ORIGIN=

# =========================================
# Lainnya
# =========================================
MAX_UPLOAD_SIZE=2097152              # Max upload file (bytes, default 2MB)
BASE_URL=http://localhost:3003       # URL publik untuk webhook payload
